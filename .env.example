# SYNAPSE Environment Configuration
# Copy this file to .env and fill in your values

# Kafka
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_GROUP_ID=synapse

# Databases
DB_URL=postgresql+asyncpg://synapse:synapse_secret@localhost/synapse
REDIS_URL=redis://localhost:6379

# Service URLs (for local development, use docker hostnames in docker-compose)
FLEET_HEALTH_URL=http://localhost:8003
DRIVER_URL=http://localhost:8002
ROUTING_URL=http://localhost:8004
SUPPLY_CHAIN_URL=http://localhost:8005
INSIGHT_FUSION_URL=http://localhost:8006
ACTUATION_URL=http://localhost:8008

# ML / Model paths
MODEL_REGISTRY_PATH=./ml/models/registry
MLFLOW_TRACKING_URI=http://localhost:5000

# Security (change these in production!)
JWT_SECRET=synapse-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# RL Training
RL_TOTAL_EPISODES=10000
RL_GPU_COUNT=1

# Emissions
DIESEL_EMISSION_FACTOR_KG_PER_LITER=2.68

# MQTT broker
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
